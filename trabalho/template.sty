% =========================================================
% COMANDOS PERSONALIZADOS PARA LISTAS DE EXERCÍCIO
% =========================================================

% 1. Comando para o enunciado do exercício
% Argumento Opcional [#1]: Referência/Fonte do exercício (ex: Zill - Seção 1.1)
\newcounter{numExercicio}
\newcommand{\exercicio}[1][]{%
    \stepcounter{numExercicio}% Incrementa o contador em +1 a cada uso
    \vspace{0.5cm}%
    \noindent\textbf{\hyperlink{resp:ex\thenumExercicio}{\hypertarget{quest:ex\thenumExercicio}{Exercício \thenumExercicio}}}%
    \ifthenelse{\isempty{#1}}{:}{ (#1):}%
}

% 2. Ambiente para padronizar as listas de itens nas questões (a, b, c...)
% Argumento Opcional [#1]: Número de colunas (Padrão = 1)
\newenvironment{itensquestao}[1][1]{%
    \def\numcolunas{#1}% Salva o número de colunas para usar no fechamento
    \ifthenelse{\equal{#1}{1}}{}{% Se for diferente de 1, abre o multicols
        \begin{multicols}{#1}
    }%
    \begin{enumerate}[label=\alph*)]
}{%
    \end{enumerate}
    \ifthenelse{\equal{\numcolunas}{1}}{}{% Se for diferente de 1, fecha o multicols
        \end{multicols}
    }%
}

% 3. Ambiente para a caixa de resolução
% Cria o contador para as resoluções
\newcounter{numResolucao}
\newcounter{itemRes}
\newenvironment{resolucao}{%
    \stepcounter{numResolucao}% Avança o número do exercício
    \setcounter{itemRes}{0}% Zera a contagem das letras a cada novo exercício
    \begin{tcolorbox}[enhanced, breakable, colback=blue!1!white, colframe=blue!75!black, title=\textbf{\hyperlink{quest:ex\thenumResolucao}{\hypertarget{resp:ex\thenumResolucao}{Exercício \thenumResolucao}}}]
}{%
    \end{tcolorbox}
}

% 4. Comando para o destaque dos itens na resolução (Letra automática)
\newcommand{\itemresolucao}{%
    \stepcounter{itemRes}% Avança a letra (1=a, 2=b, 3=c...)
    \noindent\textcolor{blue}{\textbf{Item \alph{itemRes})}} %
}